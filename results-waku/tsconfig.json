{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@devographics/filesystem": [
        "./src/shims/devographics-filesystem.d.ts"
      ],
      "@devographics/i18n/server": [
        "./src/shims/devographics-i18n-server.d.ts"
      ]
    }
  },
  "include": [
    "src",
    ".storybook"
  ],
  "exclude": [
    "src/surveys"
  ]
}
